---
import '../styles/global.css';

const profile = {
  name: 'Müslüm GÜZEL',
  role: 'Software Developer',
  summary:
    'Kurumsal uygulamalar ve entegrasyon katmanlarında .NET, React, Go ve API tabanlı sistemlerle çalışıyorum.',
  whatIDo:
    'Sade ve sürdürülebilir yazılım geliştirme yaklaşımıyla backend, frontend ve AI destekli entegrasyon akışlarında üretim yapıyorum.',
  stack: [
    '.NET Core / C#',
    'React',
    'Go',
    'REST API',
    'MCP / LLM Integrations',
    'CI/CD',
    'Azure DevOps',
    'Jira / Confluence',
    'SonarQube',
    'GitHub Copilot',
  ],
  links: [
    { label: 'LinkedIn', href: 'https://www.linkedin.com/in/muslum-guzel-2b60037a' },
    { label: 'GitHub', href: 'https://github.com/muslumguzel' },
    { label: 'Medium', href: 'https://medium.com/@muslumguzel' },
  ],
};

const meta = {
  title: 'Müslüm GÜZEL · Software Developer',
  description: 'Sade teknik profil: isim, meslek, ne iş yaptığı ve tech stack.',
  url: 'https://muslumguzel.com',
};
---

<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta name="author" content={profile.name} />
    <meta name="keywords" content=".NET, React, Go, MCP, software developer" />
    <link rel="canonical" href={meta.url} />
    <link rel="icon" type="image/svg+xml" href="/cv-site/favicon.svg" />

    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={meta.url} />

    <style>
      :root {
        --paper: #f4f5f6;
        --ink: #172228;
        --muted: #5f6c73;
        --line: #d9dde1;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: 'Avenir Next', 'Gill Sans', 'Trebuchet MS', sans-serif;
      }

      .hero {
        position: relative;
        min-height: 84vh;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(7, 20, 33, 0.5), rgba(9, 24, 39, 0.75)),
          radial-gradient(120% 90% at 20% 18%, rgba(161, 196, 220, 0.42), transparent 60%),
          linear-gradient(155deg, #2a4862 0%, #1a334a 42%, #12273c 100%);
      }

      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          repeating-linear-gradient(-19deg, rgba(220, 236, 247, 0.2) 0 7px, rgba(145, 173, 191, 0.06) 7px 15px),
          linear-gradient(90deg, rgba(8, 18, 31, 0.2), rgba(8, 18, 31, 0.55));
        mix-blend-mode: screen;
        opacity: 0.5;
      }

      .hero::after {
        content: '';
        position: absolute;
        left: 19%;
        right: 22%;
        top: 12%;
        bottom: -8%;
        background:
          linear-gradient(180deg, rgba(214, 233, 245, 0.38), rgba(196, 220, 238, 0.06)),
          repeating-linear-gradient(-15deg, rgba(229, 241, 249, 0.35) 0 6px, rgba(158, 187, 206, 0.22) 6px 12px);
        clip-path: polygon(19% 0%, 34% 7%, 48% 2%, 65% 10%, 80% 0%, 100% 24%, 84% 49%, 70% 74%, 60% 100%, 38% 100%, 31% 78%, 16% 62%, 0% 34%);
        opacity: 0.46;
        filter: blur(0.5px);
      }

      .menu {
        position: absolute;
        right: 28px;
        top: 22px;
        color: rgba(238, 245, 249, 0.9);
        letter-spacing: 0.28em;
        font-size: 0.76rem;
        text-transform: uppercase;
        font-weight: 700;
        z-index: 3;
      }

      .hero-center {
        position: relative;
        z-index: 3;
        min-height: 84vh;
        display: grid;
        place-items: center;
        text-align: center;
        padding: 56px 22px;
        color: #f2f6f8;
      }

      .title-wrap {
        display: inline-flex;
        flex-direction: column;
        gap: 14px;
        align-items: center;
      }

      .title-wrap::before,
      .title-wrap::after {
        content: '';
        width: min(520px, 74vw);
        height: 1px;
        background: rgba(240, 246, 250, 0.7);
      }

      .role {
        margin: 0;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        font-size: 0.78rem;
        color: rgba(238, 245, 249, 0.85);
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 3.4rem);
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .hero-sub {
        margin: 18px 0 0;
        color: rgba(228, 239, 246, 0.9);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-size: clamp(0.72rem, 1.5vw, 1rem);
      }

      .content {
        max-width: 1020px;
        margin: -86px auto 56px;
        padding: 0 24px;
        position: relative;
        z-index: 5;
      }

      .card {
        background: #f8f9fa;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 28px;
        box-shadow: 0 24px 48px -34px rgba(16, 31, 44, 0.28);
      }

      .card + .card {
        margin-top: 14px;
      }

      .card h2 {
        margin: 0 0 10px;
        font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', serif;
        font-size: 1.7rem;
        letter-spacing: -0.01em;
      }

      .card p {
        margin: 0;
        color: #3f4d54;
        line-height: 1.65;
      }

      .stack {
        margin: 18px 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
        padding: 0;
      }

      .stack li {
        list-style: none;
        border: 1px solid #cdd5da;
        color: #1a2a33;
        background: #ffffff;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 0.88rem;
      }

      .links {
        margin-top: 12px;
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }

      .links a {
        color: #1b3d51;
        text-decoration: none;
        border-bottom: 1px solid rgba(27, 61, 81, 0.3);
        padding-bottom: 1px;
        font-weight: 560;
      }

      @media (max-width: 760px) {
        .hero,
        .hero-center {
          min-height: 72vh;
        }

        .content {
          margin-top: -58px;
          padding: 0 14px;
        }

        .card {
          padding: 22px;
        }
      }
    </style>
  </head>
  <body>
    <section class="hero" id="home">
      <span class="menu">Menu</span>

      <div class="hero-center">
        <div>
          <p class="role">{profile.role}</p>
          <div class="title-wrap">
            <h1>{profile.name}</h1>
          </div>
          <p class="hero-sub">.NET Core | React | Go | API Integrations</p>
        </div>
      </div>
    </section>

    <main class="content">
      <section class="card" id="about">
        <h2>Ne İş Yapıyorum</h2>
        <p>{profile.summary}</p>
        <p style="margin-top: 10px;">{profile.whatIDo}</p>
      </section>

      <section class="card" id="stack">
        <h2>Tech Stack</h2>
        <ul class="stack">
          {profile.stack.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="card" id="contact">
        <h2>Bağlantılar</h2>
        <div class="links">
          {profile.links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>
