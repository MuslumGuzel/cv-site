---
import '../styles/global.css';

const translations = {
  tr: {
    meta: {
      title: 'Müslüm GÜZEL · Software Developer',
      description: 'Sade teknik profil: isim, meslek, ne iş yaptığı ve tech stack.',
    },
    role: 'Software Developer',
    heroSub: '.NET Core | React | Go | API Entegrasyonları',
    aboutTitle: 'Ne İş Yapıyorum',
    summary:
      'Kurumsal uygulamalar ve entegrasyon katmanlarında .NET, React, Go ve API tabanlı sistemlerle çalışıyorum.',
    whatIDo:
      'Sade ve sürdürülebilir yazılım geliştirme yaklaşımıyla backend, frontend ve AI destekli entegrasyon akışlarında üretim yapıyorum.',
    stackTitle: 'Tech Stack',
    stack: [
      '.NET Core / C#',
      'React',
      'Go',
      'REST API',
      'MCP / LLM Integrations',
      'CI/CD',
      'Azure DevOps',
      'Jira / Confluence',
      'SonarQube',
      'GitHub Copilot',
    ],
    linksTitle: 'Bağlantılar',
    links: [
      { label: 'LinkedIn', href: 'https://www.linkedin.com/in/muslum-guzel-2b60037a' },
      { label: 'GitHub', href: 'https://github.com/muslumguzel' },
      { label: 'Medium', href: 'https://medium.com/@muslumguzel' },
    ],
  },
  en: {
    meta: {
      title: 'Muslum Guzel · Software Developer',
      description: 'Minimal technical profile with role, focus, and tech stack.',
    },
    role: 'Software Developer',
    heroSub: '.NET Core | React | Go | API Integrations',
    aboutTitle: 'What I Do',
    summary:
      'I work on enterprise applications and integration layers using .NET, React, Go, and API-driven systems.',
    whatIDo:
      'I focus on maintainable software delivery across backend, frontend, and AI-assisted integration flows.',
    stackTitle: 'Tech Stack',
    stack: [
      '.NET Core / C#',
      'React',
      'Go',
      'REST API',
      'MCP / LLM Integrations',
      'CI/CD',
      'Azure DevOps',
      'Jira / Confluence',
      'SonarQube',
      'GitHub Copilot',
    ],
    linksTitle: 'Links',
    links: [
      { label: 'LinkedIn', href: 'https://www.linkedin.com/in/muslum-guzel-2b60037a' },
      { label: 'GitHub', href: 'https://github.com/muslumguzel' },
      { label: 'Medium', href: 'https://medium.com/@muslumguzel' },
    ],
  },
  de: {
    meta: {
      title: 'Muslum Guzel · Softwareentwickler',
      description: 'Minimales technisches Profil mit Rolle, Fokus und Tech-Stack.',
    },
    role: 'Softwareentwickler',
    heroSub: '.NET Core | React | Go | API-Integrationen',
    aboutTitle: 'Was Ich Mache',
    summary:
      'Ich arbeite an Enterprise-Anwendungen und Integrationsschichten mit .NET, React, Go und API-basierten Systemen.',
    whatIDo:
      'Mein Fokus liegt auf wartbarer Umsetzung in Backend-, Frontend- und KI-gestützten Integrationsabläufen.',
    stackTitle: 'Tech Stack',
    stack: [
      '.NET Core / C#',
      'React',
      'Go',
      'REST API',
      'MCP / LLM Integrations',
      'CI/CD',
      'Azure DevOps',
      'Jira / Confluence',
      'SonarQube',
      'GitHub Copilot',
    ],
    linksTitle: 'Links',
    links: [
      { label: 'LinkedIn', href: 'https://www.linkedin.com/in/muslum-guzel-2b60037a' },
      { label: 'GitHub', href: 'https://github.com/muslumguzel' },
      { label: 'Medium', href: 'https://medium.com/@muslumguzel' },
    ],
  },
};

const defaultLang = 'tr';
const initial = translations[defaultLang];
const profileName = 'Müslüm GÜZEL';

const meta = {
  title: initial.meta.title,
  description: initial.meta.description,
  url: 'https://muslumguzel.com',
};
---

<!DOCTYPE html>
<html lang={defaultLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta name="author" content={profileName} />
    <meta name="keywords" content=".NET, React, Go, MCP, software developer" />
    <link rel="canonical" href={meta.url} />
    <link rel="icon" type="image/svg+xml" href="/cv-site/favicon.svg" />

    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={meta.url} />

    <style>
      :root {
        --paper: #f4f5f6;
        --ink: #172228;
        --muted: #5f6c73;
        --line: #d9dde1;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: 'Avenir Next', 'Gill Sans', 'Trebuchet MS', sans-serif;
      }

      .hero {
        position: relative;
        min-height: 84vh;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(7, 20, 33, 0.5), rgba(9, 24, 39, 0.75)),
          radial-gradient(120% 90% at 20% 18%, rgba(161, 196, 220, 0.42), transparent 60%),
          linear-gradient(155deg, #2a4862 0%, #1a334a 42%, #12273c 100%);
      }

      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          repeating-linear-gradient(-19deg, rgba(220, 236, 247, 0.2) 0 7px, rgba(145, 173, 191, 0.06) 7px 15px),
          linear-gradient(90deg, rgba(8, 18, 31, 0.2), rgba(8, 18, 31, 0.55));
        mix-blend-mode: screen;
        opacity: 0.5;
      }

      .hero::after {
        content: '';
        position: absolute;
        left: 19%;
        right: 22%;
        top: 12%;
        bottom: -8%;
        background:
          linear-gradient(180deg, rgba(214, 233, 245, 0.38), rgba(196, 220, 238, 0.06)),
          repeating-linear-gradient(-15deg, rgba(229, 241, 249, 0.35) 0 6px, rgba(158, 187, 206, 0.22) 6px 12px);
        clip-path: polygon(19% 0%, 34% 7%, 48% 2%, 65% 10%, 80% 0%, 100% 24%, 84% 49%, 70% 74%, 60% 100%, 38% 100%, 31% 78%, 16% 62%, 0% 34%);
        opacity: 0.46;
        filter: blur(0.5px);
      }

      .menu {
        position: absolute;
        right: 28px;
        top: 20px;
        z-index: 4;
      }

      .lang-switch {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: 1px solid rgba(238, 245, 249, 0.35);
        border-radius: 999px;
        padding: 4px;
        background: rgba(10, 24, 37, 0.32);
        backdrop-filter: blur(4px);
      }

      .lang-btn {
        appearance: none;
        border: 0;
        background: transparent;
        color: rgba(236, 244, 248, 0.86);
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 700;
        border-radius: 999px;
        padding: 7px 10px;
        cursor: pointer;
      }

      .lang-btn.is-active {
        background: rgba(244, 249, 252, 0.96);
        color: #15222b;
      }

      .hero-center {
        position: relative;
        z-index: 3;
        min-height: 84vh;
        display: grid;
        place-items: center;
        text-align: center;
        padding: 56px 22px;
        color: #f2f6f8;
      }

      .title-wrap {
        display: inline-flex;
        flex-direction: column;
        gap: 14px;
        align-items: center;
      }

      .title-wrap::before,
      .title-wrap::after {
        content: '';
        width: min(520px, 74vw);
        height: 1px;
        background: rgba(240, 246, 250, 0.7);
      }

      .role {
        margin: 0;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        font-size: 0.78rem;
        color: rgba(238, 245, 249, 0.85);
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 3.4rem);
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .hero-sub {
        margin: 18px 0 0;
        color: rgba(228, 239, 246, 0.9);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-size: clamp(0.72rem, 1.5vw, 1rem);
      }

      .content {
        max-width: 1020px;
        margin: -86px auto 56px;
        padding: 0 24px;
        position: relative;
        z-index: 5;
      }

      .card {
        background: #f8f9fa;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 28px;
        box-shadow: 0 24px 48px -34px rgba(16, 31, 44, 0.28);
      }

      .card + .card {
        margin-top: 14px;
      }

      .card h2 {
        margin: 0 0 10px;
        font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', serif;
        font-size: 1.7rem;
        letter-spacing: -0.01em;
      }

      .card p {
        margin: 0;
        color: #3f4d54;
        line-height: 1.65;
      }

      .stack {
        margin: 18px 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
        padding: 0;
      }

      .stack li {
        list-style: none;
        border: 1px solid #cdd5da;
        color: #1a2a33;
        background: #ffffff;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 0.88rem;
      }

      .links {
        margin-top: 12px;
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }

      .links a {
        color: #1b3d51;
        text-decoration: none;
        border-bottom: 1px solid rgba(27, 61, 81, 0.3);
        padding-bottom: 1px;
        font-weight: 560;
      }

      @media (max-width: 760px) {
        .hero,
        .hero-center {
          min-height: 72vh;
        }

        .menu {
          right: 14px;
          top: 14px;
        }

        .content {
          margin-top: -58px;
          padding: 0 14px;
        }

        .card {
          padding: 22px;
        }
      }
    </style>
  </head>
  <body data-active-lang={defaultLang}>
    <section class="hero" id="home">
      <div class="menu">
        <div class="lang-switch" role="group" aria-label="Language switcher">
          <button type="button" class="lang-btn is-active" data-language-option="tr" aria-pressed="true">TR</button>
          <button type="button" class="lang-btn" data-language-option="en" aria-pressed="false">EN</button>
          <button type="button" class="lang-btn" data-language-option="de" aria-pressed="false">DE</button>
        </div>
      </div>

      <div class="hero-center">
        <div>
          <p class="role" id="role-text">{initial.role}</p>
          <div class="title-wrap">
            <h1>{profileName}</h1>
          </div>
          <p class="hero-sub" id="hero-sub-text">{initial.heroSub}</p>
        </div>
      </div>
    </section>

    <main class="content">
      <section class="card" id="about">
        <h2 id="about-title-text">{initial.aboutTitle}</h2>
        <p id="summary-text">{initial.summary}</p>
        <p id="what-i-do-text" style="margin-top: 10px;">{initial.whatIDo}</p>
      </section>

      <section class="card" id="stack">
        <h2 id="stack-title-text">{initial.stackTitle}</h2>
        <ul class="stack" id="stack-list">
          {initial.stack.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="card" id="contact">
        <h2 id="links-title-text">{initial.linksTitle}</h2>
        <div class="links" id="links-list">
          {initial.links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
        </div>
      </section>
    </main>

    <script is:inline>
      const TRANSLATIONS = {
        tr: {
          meta: {
            title: 'Müslüm GÜZEL · Software Developer',
            description: 'Sade teknik profil: isim, meslek, ne iş yaptığı ve tech stack.',
          },
          role: 'Software Developer',
          heroSub: '.NET Core | React | Go | API Entegrasyonları',
          aboutTitle: 'Ne İş Yapıyorum',
          summary:
            'Kurumsal uygulamalar ve entegrasyon katmanlarında .NET, React, Go ve API tabanlı sistemlerle çalışıyorum.',
          whatIDo:
            'Sade ve sürdürülebilir yazılım geliştirme yaklaşımıyla backend, frontend ve AI destekli entegrasyon akışlarında üretim yapıyorum.',
          stackTitle: 'Tech Stack',
          stack: [
            '.NET Core / C#',
            'React',
            'Go',
            'REST API',
            'MCP / LLM Integrations',
            'CI/CD',
            'Azure DevOps',
            'Jira / Confluence',
            'SonarQube',
            'GitHub Copilot',
          ],
          linksTitle: 'Bağlantılar',
          links: [
            { label: 'LinkedIn', href: 'https://www.linkedin.com/in/muslum-guzel-2b60037a' },
            { label: 'GitHub', href: 'https://github.com/muslumguzel' },
            { label: 'Medium', href: 'https://medium.com/@muslumguzel' },
          ],
        },
        en: {
          meta: {
            title: 'Muslum Guzel · Software Developer',
            description: 'Minimal technical profile with role, focus, and tech stack.',
          },
          role: 'Software Developer',
          heroSub: '.NET Core | React | Go | API Integrations',
          aboutTitle: 'What I Do',
          summary:
            'I work on enterprise applications and integration layers using .NET, React, Go, and API-driven systems.',
          whatIDo:
            'I focus on maintainable software delivery across backend, frontend, and AI-assisted integration flows.',
          stackTitle: 'Tech Stack',
          stack: [
            '.NET Core / C#',
            'React',
            'Go',
            'REST API',
            'MCP / LLM Integrations',
            'CI/CD',
            'Azure DevOps',
            'Jira / Confluence',
            'SonarQube',
            'GitHub Copilot',
          ],
          linksTitle: 'Links',
          links: [
            { label: 'LinkedIn', href: 'https://www.linkedin.com/in/muslum-guzel-2b60037a' },
            { label: 'GitHub', href: 'https://github.com/muslumguzel' },
            { label: 'Medium', href: 'https://medium.com/@muslumguzel' },
          ],
        },
        de: {
          meta: {
            title: 'Muslum Guzel · Softwareentwickler',
            description: 'Minimales technisches Profil mit Rolle, Fokus und Tech-Stack.',
          },
          role: 'Softwareentwickler',
          heroSub: '.NET Core | React | Go | API-Integrationen',
          aboutTitle: 'Was Ich Mache',
          summary:
            'Ich arbeite an Enterprise-Anwendungen und Integrationsschichten mit .NET, React, Go und API-basierten Systemen.',
          whatIDo:
            'Mein Fokus liegt auf wartbarer Umsetzung in Backend-, Frontend- und KI-gestützten Integrationsabläufen.',
          stackTitle: 'Tech Stack',
          stack: [
            '.NET Core / C#',
            'React',
            'Go',
            'REST API',
            'MCP / LLM Integrations',
            'CI/CD',
            'Azure DevOps',
            'Jira / Confluence',
            'SonarQube',
            'GitHub Copilot',
          ],
          linksTitle: 'Links',
          links: [
            { label: 'LinkedIn', href: 'https://www.linkedin.com/in/muslum-guzel-2b60037a' },
            { label: 'GitHub', href: 'https://github.com/muslumguzel' },
            { label: 'Medium', href: 'https://medium.com/@muslumguzel' },
          ],
        },
      };

      const SUPPORTED_LANGS = ['tr', 'en', 'de'];
      const roleText = document.getElementById('role-text');
      const heroSubText = document.getElementById('hero-sub-text');
      const aboutTitleText = document.getElementById('about-title-text');
      const summaryText = document.getElementById('summary-text');
      const whatIDoText = document.getElementById('what-i-do-text');
      const stackTitleText = document.getElementById('stack-title-text');
      const stackList = document.getElementById('stack-list');
      const linksTitleText = document.getElementById('links-title-text');
      const linksList = document.getElementById('links-list');
      const languageButtons = document.querySelectorAll('[data-language-option]');
      const titleElement = document.querySelector('title');
      const descriptionElement = document.querySelector('meta[name="description"]');

      function renderStack(items) {
        stackList.replaceChildren();
        for (let i = 0; i < items.length; i += 1) {
          const li = document.createElement('li');
          li.textContent = items[i];
          stackList.appendChild(li);
        }
      }

      function renderLinks(items) {
        linksList.replaceChildren();
        for (let i = 0; i < items.length; i += 1) {
          const link = items[i];
          const anchor = document.createElement('a');
          anchor.href = link.href;
          anchor.textContent = link.label;
          anchor.target = '_blank';
          anchor.rel = 'noreferrer';
          linksList.appendChild(anchor);
        }
      }

      function updateLanguageButtons(activeLang) {
        for (let i = 0; i < languageButtons.length; i += 1) {
          const button = languageButtons[i];
          const lang = button.getAttribute('data-language-option');
          const isActive = lang === activeLang;
          button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          button.classList.toggle('is-active', isActive);
        }
      }

      function applyLanguage(lang) {
        const content = TRANSLATIONS[lang] || TRANSLATIONS.tr;

        roleText.textContent = content.role;
        heroSubText.textContent = content.heroSub;
        aboutTitleText.textContent = content.aboutTitle;
        summaryText.textContent = content.summary;
        whatIDoText.textContent = content.whatIDo;
        stackTitleText.textContent = content.stackTitle;
        linksTitleText.textContent = content.linksTitle;

        renderStack(content.stack);
        renderLinks(content.links);

        titleElement.textContent = content.meta.title;
        descriptionElement.setAttribute('content', content.meta.description);

        document.documentElement.lang = lang;
        document.body.dataset.activeLang = lang;
        updateLanguageButtons(lang);
        localStorage.setItem('preferredLang', lang);
      }

      function detectBrowserLanguage() {
        const candidates = [];
        if (Array.isArray(navigator.languages)) {
          candidates.push(...navigator.languages);
        }
        if (navigator.language) {
          candidates.push(navigator.language);
        }

        for (let i = 0; i < candidates.length; i += 1) {
          const value = candidates[i];
          if (!value) continue;
          const lower = value.toLowerCase();
          if (lower.indexOf('tr') === 0) return 'tr';
          if (lower.indexOf('de') === 0) return 'de';
          if (lower.indexOf('en') === 0) return 'en';
        }

        return 'tr';
      }

      function initialiseLanguage() {
        const stored = localStorage.getItem('preferredLang');
        const startLang = SUPPORTED_LANGS.indexOf(stored) !== -1 ? stored : detectBrowserLanguage();
        applyLanguage(startLang);

        for (let i = 0; i < languageButtons.length; i += 1) {
          const button = languageButtons[i];
          button.addEventListener('click', function (event) {
            const selected = event.currentTarget.getAttribute('data-language-option');
            if (SUPPORTED_LANGS.indexOf(selected) === -1) return;
            if (selected === document.body.dataset.activeLang) return;
            applyLanguage(selected);
          });
        }
      }

      initialiseLanguage();
    </script>
  </body>
</html>
